# ============================================
# AI Content Hub — Environment Configuration
# ============================================

# === General ===
APP_NAME=AI Content Hub
DATA_DIR=./data
LOG_LEVEL=INFO

# === Sources ===
# Comma-separated list of enabled sources
SOURCES_ENABLED=linkedin,reddit,techcrunch,techgig,arxiv,youtube,hackernews,medium,rss,newsapi,devto,demo

# === LinkedIn ===
# Option A: Playwright scraper (email/password)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
# Option B: Proxycurl API
LINKEDIN_PROXYCURL_API_KEY=
LINKEDIN_SCRAPE_INTERVAL_MINUTES=360

# === Reddit (free OAuth2) ===
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=AI-Content-Hub/1.0
REDDIT_SCRAPE_INTERVAL_MINUTES=60
REDDIT_SUBREDDITS=artificial,artificialintelligence,MachineLearning,LangChain,LocalLLaMA,Rag,vectordatabase,ClaudeAI,OpenAI,StableDiffusion

# === TechCrunch (free RSS) ===
TECHCRUNCH_SCRAPE_INTERVAL_MINUTES=120

# === TechGig ===
TECHGIG_SCRAPE_INTERVAL_MINUTES=360

# === ArXiv (free API) ===
ARXIV_SCRAPE_INTERVAL_MINUTES=180
ARXIV_CATEGORIES=cs.AI,cs.LG,cs.CL,cs.CV,cs.RO,cs.IR,cs.MA,cs.SE

# === YouTube (requires API key) ===
YOUTUBE_API_KEY=
YOUTUBE_SCRAPE_INTERVAL_MINUTES=120
YOUTUBE_CHANNELS=
# Comma-separated channel IDs (default AI ones):
# Two Minute Papers, Yannic Kilcher, AI Explained

# === Hacker News (free Firebase API) ===
HN_SCRAPE_INTERVAL_MINUTES=30

# === Medium (free RSS) ===
MEDIUM_SCRAPE_INTERVAL_MINUTES=180
MEDIUM_TAGS=artificial-intelligence,machine-learning,deep-learning,llm,agent,langchain,rag,vectordatabase

# === RSS (generic feeds) ===
RSS_SCRAPE_INTERVAL_MINUTES=120
RSS_FEED_URLS=https://feeds.feedburner.com/TheAIDaily,https://a16z.com/feed,https://news.ycombinator.com/rss,https://blog.google/technology/ai/rss,https://openai.com/blog/rss,https://andrewchen.substack.com/feed

# === NewsAPI (requires API key, free tier available) ===
NEWSAPI_API_KEY=
NEWSAPI_SCRAPE_INTERVAL_MINUTES=120
NEWSAPI_QUERIES=artificial intelligence,AI agents,deep learning,LLM,robotics,quantum computing

# === dev.to (free API) ===
DEVTO_SCRAPE_INTERVAL_MINUTES=120
DEVTO_TAGS=ai,machinelearning,deeplearning,llm,agents,python,rag

# === Pipeline ===
# LLM for classification: none, openai, anthropic, ollama
LLM_PROVIDER=none
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
CLASSIFICATION_METHOD=hybrid
EMBEDDING_MODEL=all-MiniLM-L6-v2

# === Storage ===
CHROMA_DB_PATH=./data/chroma_db
SQL_DB_PATH=./data/content_hub.db

# === API ===
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000,http://localhost:8501

# === Digest ===
DIGEST_INTERVAL_MINUTES=360
DIGEST_FORMAT=markdown
DIGEST_TOPICS=AI,AgenticAI,AI_Frameworks,Quantum_Computing,Robotics,RAG,MCP,LLM_Ops
DIGEST_SLACK_WEBHOOK=
DIGEST_DISCORD_WEBHOOK=
DIGEST_MAX_PER_TOPIC=10

# === Dashboard Auth ===
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=admin123

# === AI Features ===
SUMMARIZER_DEFAULT_LENGTH=normal
RECOMMENDER_DEFAULT_N=5
RAG_MAX_CONTEXT=5
RAG_SYSTEM_PROMPT=You are an AI assistant answering questions based on scraped content. Answer concisely using only the provided context.

# === Email Notifications (SMTP) ===
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=ai-content-hub@localhost

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Webhooks ===
WEBHOOK_CONFIG_PATH=./data/webhooks.json

# === JWT Auth ===
JWT_SECRET_KEY=change-this-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_TOKEN_EXPIRY_HOURS=24
AUTH_DB_PATH=./data/auth.db
API_RATE_LIMIT_PER_MINUTE=100

# === Processing ===
FULLTEXT_EXTRACT_TIMEOUT=30
DEDUP_SIMILARITY_THRESHOLD=0.85
RATE_LIMIT_DEFAULT_RPM=10

# === Enterprise Integrations ===
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
TEAMS_WEBHOOK_URL=
GOOGLE_DRIVE_CREDS_PATH=
NOTION_API_KEY=
NOTION_DATABASE_ID=

# === Compliance ===
AUDIT_DB_PATH=./data/audit.db
RETENTION_DB_PATH=./data/retention.db
MODERATION_TERMS_PATH=./data/moderation_terms.json
DEFAULT_RETENTION_DAYS=90
PII_REDACTION_ENABLED=true
CONTENT_MODERATION_ENABLED=true

# === Collaboration ===
WORKSPACES_DB_PATH=./data/workspaces.db
COMMENTS_DB_PATH=./data/comments.db
APPROVALS_DB_PATH=./data/approvals.db

# === Monitoring ===
ALERTS_DB_PATH=./data/alerts.db
COMPETITOR_DB_PATH=./data/competitors.db
ANOMALY_ALERT_THRESHOLD=2.0

# === Workflow ===
WORKFLOWS_DB_PATH=./data/workflows.db
WORKFLOW_TIMEOUT_SECONDS=300

# === Search ===
SEARCH_ANALYTICS_DB_PATH=./data/search_analytics.db
SAVED_SEARCHES_DB_PATH=./data/saved_searches.db
SEARCH_PAGE_SIZE_DEFAULT=20
