{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksVersion": "1",
    "buildCommand": "pip install -r pipeline/requirements.txt"
  },
  "deploy": {
    "startCommand": "python -m pipeline api",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
